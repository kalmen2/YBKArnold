rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    // CRM opportunity quote documents uploaded from Sales Opportunities page.
    match /crm/opportunities/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // CRM sales rep logos uploaded from Sales Reps page.
    match /crm/sales-rep-logos/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Block all other storage paths by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
