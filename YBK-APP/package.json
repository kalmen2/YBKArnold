{
  "name": "arnold",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan",
    "start:dev-client": "expo start --dev-client --clear --lan",
    "android": "expo run:android",
    "android:dev": "expo run:android",
    "ios": "expo run:ios",
    "ios:dev": "expo run:ios",
    "ios:prepare:local": "npx expo prebuild --platform ios --no-install",
    "ios:pods:local": "node scripts/ensure-cocoapods.cjs && cd ios && pod install",
    "ios:local:setup": "npm run ios:prepare:local && npm run ios:pods:local",
    "ios:sim:local": "npm run ios:local:setup && xcodebuild -workspace ios/YBKAPP.xcworkspace -scheme YBKAPP -configuration Debug -destination 'platform=iOS Simulator,name=iPhone 16e' build",
    "ios:archive:local": "npm run ios:local:setup && xcodebuild -workspace ios/YBKAPP.xcworkspace -scheme YBKAPP -configuration Release -destination 'generic/platform=iOS' -archivePath ios/build/YBKAPP.xcarchive archive",
    "ios:open:xcode": "npm run ios:local:setup && open ios/YBKAPP.xcworkspace",
    "web": "expo start --web",
    "android:prepare:local": "node scripts/ensure-android-sdk.cjs",
    "android:clean:local": "npm run android:prepare:local && cd android && ./gradlew clean",
    "android:apk:local": "npm run android:prepare:local && cd android && ./gradlew assembleRelease -x lint -x test",
    "android:apk:local:copy": "cp android/app/build/outputs/apk/release/app-release.apk ./YBK-APP-local-release.apk",
    "android:apk:local:all": "npm run android:apk:local && npm run android:apk:local:copy",
    "android:install:local": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/fix-expo-auth-session-tsconfig.cjs",
    "eas:login": "eas login",
    "eas:android:dev": "eas build --profile development --platform android",
    "eas:android:dev:status": "eas build:list --platform android --limit 3",
    "eas:android:play": "eas build --profile android-play --platform android",
    "eas:android:apk": "eas build --profile android-apk --platform android",
    "eas:android:pk": "eas build --profile android-apk --platform android",
    "eas:ios:store": "eas build --profile ios-store --platform ios",
    "eas:update:production": "eas update --channel production --message \"YBK OTA update\"",
    "eas:update:preview": "eas update --channel preview --message \"YBK preview OTA update\"",
    "eas:update:list": "eas update:list --branch production --limit 10",
    "eas:channel:list": "eas channel:list",
    "eas:submit:android": "eas submit --profile android-play --platform android --latest",
    "eas:submit:ios": "eas submit --profile ios-store --platform ios --latest",
    "eas:build:list": "eas build:list --limit 10"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-picker/picker": "2.11.4",
    "expo": "~55.0.14",
    "expo-auth-session": "~55.0.13",
    "expo-constants": "~55.0.13",
    "expo-dev-client": "~55.0.27",
    "expo-image-picker": "~55.0.18",
    "expo-local-authentication": "~55.0.13",
    "expo-notifications": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "~55.0.20",
    "expo-web-browser": "~55.0.14",
    "firebase": "^12.12.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "eas-cli": "^18.5.0",
    "expo-module-scripts": "^55.0.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
