{
  "name": "ybk-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan",
    "start:dev-client": "expo start --dev-client --clear --lan",
    "android": "expo run:android",
    "android:dev": "expo run:android",
    "ios": "expo run:ios",
    "ios:dev": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/fix-expo-auth-session-tsconfig.cjs",
    "eas:login": "eas login",
    "eas:android:dev": "eas build --profile development --platform android",
    "eas:android:dev:status": "eas build:list --platform android --limit 3",
    "eas:android:play": "eas build --profile android-play --platform android",
    "eas:android:apk": "eas build --profile android-apk --platform android",
    "eas:android:pk": "eas build --profile android-apk --platform android",
    "eas:ios:store": "eas build --profile ios-store --platform ios",
    "eas:update:production": "eas update --channel production --message \"YBK OTA update\"",
    "eas:update:preview": "eas update --channel preview --message \"YBK preview OTA update\"",
    "eas:update:list": "eas update:list --branch production --limit 10",
    "eas:channel:list": "eas channel:list",
    "eas:submit:android": "eas submit --profile android-play --platform android --latest",
    "eas:submit:ios": "eas submit --profile ios-store --platform ios --latest",
    "eas:build:list": "eas build:list --limit 10"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-picker/picker": "2.11.1",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-image-picker": "~17.0.10",
    "expo-local-authentication": "~17.0.7",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.8",
    "firebase": "^12.12.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eas-cli": "^18.5.0",
    "expo-module-scripts": "^55.0.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
