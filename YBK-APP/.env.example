# Google OAuth client IDs for Expo mobile sign-in.
# Recommended: use development builds (not Expo Go) and fill only WEB + IOS + ANDROID.
# Create OAuth 2.0 Client IDs in Google Cloud Console under the same Firebase project,
# then copy this file to .env and fill values.

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Optional: Expo Go-only fallback values.
# Expo Go identifiers are different from your real app identifiers.
# iOS bundle id in Expo Go: host.exp.Exponent
# Android package in Expo Go: host.exp.exponent
# Note: Android Expo Go also needs Expo Go signing SHA-1, so development builds are usually easier.
EXPO_PUBLIC_GOOGLE_EXPO_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_EXPO_ANDROID_CLIENT_ID=

# App update URLs are controlled by backend env vars:
# - MOBILE_ANDROID_UPDATE_URL
# - MOBILE_ANDROID_LATEST_BUILD
# - MOBILE_ANDROID_LATEST_VERSION
# - MOBILE_IOS_UPDATE_URL
# - MOBILE_IOS_LATEST_BUILD
# - MOBILE_IOS_LATEST_VERSION
# Keep update configuration in backend only to avoid split sources.

# Optional Firebase overrides (defaults are already baked in App)
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# EXPO_PUBLIC_FIREBASE_APP_ID=
